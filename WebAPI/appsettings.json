{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=multitenantdb;Username=postgres;Password=yourpassword"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-that-is-at-least-32-characters-long-for-production",
    "Issuer": "MultiTenantSaaS",
    "Audience": "MultiTenantSaaS",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Subscription": {
    "Plans": [
      {
        "Name": "Free",
        "Description": "Perfect for small teams getting started",
        "MonthlyPrice": 0,
        "RateLimitPerMinute": 100,
        "MaxUsers": 3,
        "Features": [
          "Basic features",
          "3 users",
          "100 requests/minute"
        ]
      },
      {
        "Name": "Professional",
        "Description": "For growing teams that need more power",
        "MonthlyPrice": 29.99,
        "RateLimitPerMinute": 1000,
        "MaxUsers": 10,
        "Features": [
          "All Free features",
          "10 users",
          "1000 requests/minute",
          "Priority support"
        ]
      },
      {
        "Name": "Enterprise",
        "Description": "For large organizations with advanced needs",
        "MonthlyPrice": 99.99,
        "RateLimitPerMinute": 5000,
        "MaxUsers": 50,
        "Features": [
          "All Professional features",
          "50 users",
          "5000 requests/minute",
          "24/7 support",
          "Custom integrations"
        ]
      }
    ]
  },
  "RBACMigration": {
    "DefaultRoles": [
      {
        "Name": "Admin",
        "Description": "Full administrative access",
        "IsDefault": false
      },
      {
        "Name": "Manager",
        "Description": "Manager level access",
        "IsDefault": false
      },
      {
        "Name": "User",
        "Description": "Basic user access",
        "IsDefault": true
      }
    ],
    "DefaultPermissions": [
      {
        "Name": "project.read",
        "Description": "Read and view projects",
        "Category": "Projects"
      },
      {
        "Name": "project.write",
        "Description": "Create and edit projects",
        "Category": "Projects"
      },
      {
        "Name": "project.delete",
        "Description": "Delete projects",
        "Category": "Projects"
      },
      {
        "Name": "user.manage",
        "Description": "Manage users in tenant",
        "Category": "Users"
      },
      {
        "Name": "subscription.manage",
        "Description": "Manage subscription and billing",
        "Category": "Subscription"
      },
      {
        "Name": "tenant.admin",
        "Description": "Full tenant administration",
        "Category": "Tenant"
      }
    ],
    "RolePermissionMappings": [
      {
        "Role": "Admin",
        "Permissions": [
          "project.read",
          "project.write", 
          "project.delete",
          "user.manage",
          "subscription.manage",
          "tenant.admin"
        ]
      },
      {
        "Role": "Manager",
        "Permissions": [
          "project.read",
          "project.write",
          "project.delete",
          "user.manage"
        ]
      },
      {
        "Role": "User",
        "Permissions": [
          "project.read"
        ]
      }
    ],
    "UserRoleMappings": [
      {
        "UserRole": "Admin",
        "AssignedRole": "Admin",
        "Priority": 3
      },
      {
        "UserRole": "Manager",
        "AssignedRole": "Manager",
        "Priority": 2
      },
      {
        "UserRole": "User",
        "AssignedRole": "User",
        "Priority": 1
      }
    ]
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "HostName": "localhost",
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "Port": "5672",
    "SslEnabled": "false"
  },
  "OrderQueue": {
    "Exchange": "order.exchange",
    "Queue": "order.queue",
    "StatusQueue": "order.status.queue",
    "Durable": true
  }
}
